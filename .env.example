NODE_ENV=development
PORT=3000

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DB_NAME=realestate
MONGO_URI=mongodb://127.0.0.1:27017/realestate
# Docker example:
# MONGO_URI=mongodb://admin:password@mongo:27017/realestate?authSource=admin

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_EXPIRESIN=15m
REFRESH_EXPIRESIN=30d
ALGORITHM=HS256

ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
ACCESS_COOKIE_MAX_AGE_MS=900000
REFRESH_COOKIE_MAX_AGE_MS=2592000000
ACCESS_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SAMESITE=lax
COOKIE_SAMESITE=lax
