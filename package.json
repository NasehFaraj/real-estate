{
    "name": "real-estate",
    "version": "1.0.0",
    "description": "",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "check": "npm run format:check && npm run lint && npm run typecheck",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/NasehFaraj/real-estate.git"
    },
    "author": "NasehFaraj",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/NasehFaraj/real-estate/issues"
    },
    "homepage": "https://github.com/NasehFaraj/real-estate#readme",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^9.1.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.9",
        "@types/cors": "^2.8.17",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^24.10.9",
        "@types/supertest": "^6.0.3",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "supertest": "^7.0.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.2"
    }
}
